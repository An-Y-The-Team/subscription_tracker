# docker-compose.yml reads these. .env is gitignored — never commit real secrets.

# ─────────────────────────────────────────────────────────────────────────────
# Authentik (OIDC identity provider) — consumed by the authentik-* services
# ─────────────────────────────────────────────────────────────────────────────

# Pin to the current stable release from https://goauthentik.io/docs/releases
# (verify the tag exists on ghcr.io/goauthentik/server before bringing it up).
# 2026.5 is the newest but ships an IPv6-only listen-address change; 2026.2 is the
# newest stable before it and is the recommended default for this dev setup.
AUTHENTIK_TAG=2026.2

# Strong random key. Generate with:  openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=dev-only-insecure-secret-change-me-0000000000000000

# Authentik's OWN database (separate from the app's "db" service).
AUTHENTIK_PG_USER=authentik
AUTHENTIK_PG_DB=authentik
# Generate with:  openssl rand -base64 36 | tr -d '\n'
AUTHENTIK_PG_PASS=authentik-dev-password

# ─────────────────────────────────────────────────────────────────────────────
# Backend OIDC client + session — filled AFTER the one-time Authentik bootstrap
# (Part A wires these into FastAPI; listed here so the env contract is in one place)
# ─────────────────────────────────────────────────────────────────────────────

# From the OAuth2/OpenID provider you create in the Authentik admin UI.
# Issuer is http://localhost:9000/application/o/<app-slug>/  (note trailing slash)
OIDC_DISCOVERY_URL=http://localhost:9000/application/o/<app-slug>/.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback
OIDC_SCOPES=openid profile email
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/

# Frontend redirect target after a successful login.
FRONTEND_POST_LOGIN_URL=http://localhost:3000/
FRONTEND_URL=http://localhost:3000

# App session cookie (issued by the FastAPI BFF). Dev defaults below; in prod set
# SESSION_COOKIE_SECURE=true, SESSION_COOKIE_DOMAIN=.your-domain.com (same site).
SESSION_COOKIE_NAME=hm_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=604800
# Signs Authlib's transient flow cookie. Generate with: openssl rand -base64 48 | tr -d '\n'
SESSION_SECRET=dev-only-insecure-session-secret-change-me
